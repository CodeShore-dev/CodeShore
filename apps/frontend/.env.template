# 前端應用程式標題（顯示於瀏覽器分頁標題等處）
VITE_APP_TITLE=

# Supabase 專案 URL（前端使用，會被打包進客戶端程式碼，非機密資訊）
# 取得方式：Supabase Dashboard > Project Settings > API > Project URL
VITE_SUPABASE_URL=

# Supabase Anon/Publishable Key（前端使用，會被打包進客戶端程式碼，非機密資訊，權限受 RLS 限制）
# 取得方式：Supabase Dashboard > Project Settings > API > anon public key
VITE_SUPABASE_ANON_KEY=

# 具有管理員權限的使用者 Email 清單（以逗號分隔多筆，前端用於顯示/隱藏管理功能）
VITE_ADMIN_EMAILS=

# GA4 Measurement ID（格式 G-XXXXXXXXXX，前端使用，非機密資訊）
# 取得方式：Google Analytics > 管理 > 資料串流 > 選擇串流 > Measurement ID
# 未設定時停用 GA 追蹤（開發模式一律停用，不受此變數影響）
VITE_GA_MEASUREMENT_ID=
