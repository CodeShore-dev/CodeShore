# Supabase 專案的 Service Role Key（具完整資料庫存取權限，僅可用於後端，切勿外洩或用於前端）
# 取得方式：Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Supabase 專案 URL
# 取得方式：Supabase Dashboard > Project Settings > API > Project URL
SUPABASE_URL=

# OpenRouter API Key，用於呼叫 OpenRouter 上的 LLM 模型
# 取得方式：https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Puppeteer 使用的 Chrome/Chromium 執行檔路徑（爬蟲用瀏覽器自動化）
# 範例（WSL 下呼叫 Windows Chrome）：/mnt/c/Program Files/Google/Chrome/Application/chrome.exe
PUPPETEER_EXECUTABLE_PATH=

# 具有管理員權限的使用者 Email 清單（以逗號分隔多筆）
ADMIN_EMAILS=

# Supabase 資料庫連線密碼（用於直接連線 Postgres，例如 migration 工具）
# 取得方式：Supabase Dashboard > Project Settings > Database > Connection string 中的密碼
SUPABASE_DB_PASSWORD=

# Supabase CLI / Management API 存取權杖
# 取得方式：Supabase Dashboard > Account > Access Tokens
SUPABASE_ACCESS_TOKEN=
